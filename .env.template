# Pare Email Suite - Environment Variables Template
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control (it's in .gitignore)

# Flask Configuration
# Generate a strong secret key with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=your-secret-key-here

# Google OAuth Configuration
# Get these from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# OAuth Redirect URI (optional - will be auto-detected if not set)
# For local development: http://localhost:5001/oauth2callback
# For production: https://pare.up.railway.app/oauth2callback
# GOOGLE_REDIRECT_URI=http://localhost:5001/oauth2callback

# OpenAI API Key
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key

# Railway Configuration (auto-set by Railway, optional for local dev)
# RAILWAY_PUBLIC_DOMAIN=pare.up.railway.app

# Database (optional - defaults to SQLite)
# DATABASE_URL=sqlite:///pare.sqlite3

# Frontend Redirect URL (where to redirect after OAuth login)
# For local development: http://localhost:5173
# For production: https://pare.up.railway.app
FRONTEND_REDIRECT_URL=http://localhost:5173
